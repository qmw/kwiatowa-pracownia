---
import Layout from "../layouts/Layout.astro";

const navLinks = [
  { href: "#o-pracowni", label: "O Pracowni" },
  { href: "#oferta", label: "Oferta" },
  { href: "#galeria", label: "Galeria" },
  { href: "#zamowienie", label: "Zamówienie" },
  { href: "#kontakt", label: "Kontakt" },
];

const services = [
  {
    icon: "✿",
    title: "Bukiety Okolicznościowe",
    desc: "Ręcznie komponowane bukiety na urodziny, imieniny, rocznice i każdą wyjątkową chwilę. Każdy jest jedynym w swoim rodzaju.",
    price: "od 80 zł",
    img: "photo-1487530811015-780780169993",
  },
  {
    icon: "◇",
    title: "Florystyka Ślubna",
    desc: "Wiązanki ślubne, dekoracje stołów, łuki kwiatowe, chodniki — tworzymy spójną narrację kwiatową na Wasz wyjątkowy dzień.",
    price: "od 600 zł",
    img: "photo-1519225421980-715cb0215aed",
  },
  {
    icon: "❀",
    title: "Wiązanki & Kosze",
    desc: "Eleganckie kompozycje w koszach wiklinowych, welurowych pudłach i papierze czerpanym. Idealne jako prezent.",
    price: "od 120 zł",
    img: "photo-1490750967868-88df5691cc6c",
  },
  {
    icon: "✦",
    title: "Kwiaty na Okazje",
    desc: "Chrzciny, komunie, baby shower, pożegnania, firmowe gale — dobieramy kompozycje dopasowane do nastroju i miejsca.",
    price: "od 150 zł",
    img: "photo-1467043237213-65f2da53396f",
  },
  {
    icon: "⟡",
    title: "Abonament Kwiatowy",
    desc: "Regularne dostawy świeżych kompozycji do domu lub biura — co tydzień, co dwa tygodnie lub raz w miesiącu.",
    price: "od 180 zł / mies.",
    img: "photo-1520763185298-1b434c919102",
  },
];

const galleryItems = [
  { img: "photo-1487530811015-780780169993", alt: "Bukiet z piwonii i róż", cat: "bukiety" },
  { img: "photo-1519225421980-715cb0215aed", alt: "Ślubna wiązanka z białych kwiatów", cat: "sluby" },
  { img: "photo-1490750967868-88df5691cc6c", alt: "Kosz z wiosennymi kwiatami", cat: "kompozycje" },
  { img: "photo-1562690868-60bbe7293e4b", alt: "Romantyczna kompozycja w wazonie", cat: "kompozycje" },
  { img: "photo-1508610048659-a06b669e3321", alt: "Pastelowy bukiet ślubny", cat: "sluby" },
  { img: "photo-1457296898342-cdd24585d095", alt: "Wiosenny bukiet z ranunkułów", cat: "bukiety" },
  { img: "photo-1530103862676-de8c9debad1d", alt: "Dekoracja stołu kwiatami", cat: "sluby" },
  { img: "photo-1444930694458-01babf71ab6b", alt: "Suszone kwiaty w kompozycji", cat: "kompozycje" },
  { img: "photo-1471086569966-db3eebc25a59", alt: "Kolorowy bukiet wiosennych kwiatów", cat: "bukiety" },
];

const testimonials = [
  {
    name: "Marta K.",
    event: "Ślub, sierpień 2024",
    text: "Kwiatowa Pracownia dosłownie spełniła moje marzenia o ślubie. Wiązanka była dokładnie taka, jak sobie wyobrażałam — delikatna, romantyczna, z piwoniami i eukaliptusem. Polecam z całego serca!",
  },
  {
    name: "Zofia W.",
    event: "Abonament miesięczny",
    text: "Od roku co dwa tygodnie dostaję bukiet i za każdym razem jest inaczej i pięknie. Świeże kwiaty potrafią zmienić nastrój całego domu.",
  },
  {
    name: "Anna M.",
    event: "Urodziny, maj 2024",
    text: "Zamówiłam bukiet dla mamy — dostałam przepiękną kompozycję w jej ulubionych kolorach, jeszcze przed planowaną godziną. Mama była wzruszona!",
  },
];

const okazjeOptions = [
  "Urodziny / imieniny",
  "Ślub / wesele",
  "Rocznica",
  "Chrzciny / komunia",
  "Baby shower",
  "Podziękowanie",
  "Dekoracja biura / domu",
  "Abonament kwiatowy",
  "Inna okazja",
];

const budzetOptions = [
  "do 100 zł",
  "100–200 zł",
  "200–400 zł",
  "400–800 zł",
  "powyżej 800 zł",
];
---

<Layout>
  <!-- NAV -->
  <header
    id="nav"
    class="fixed top-0 left-0 right-0 z-50 transition-all duration-300"
  >
    <div class="max-w-6xl mx-auto px-6 flex items-center justify-between h-16 md:h-20">
      <!-- Logo -->
      <a href="#" class="flex flex-col leading-none group">
        <span
          class="font-display text-2xl text-white drop-shadow-sm tracking-wide group-hover:tracking-wider transition-all duration-300"
          >Kwiatowa Pracownia</span
        >
        <span
          class="text-[0.6rem] uppercase tracking-[0.25em] text-white/70 font-body font-light"
          >florystyka autorska</span
        >
      </a>

      <!-- Desktop Nav -->
      <nav class="hidden md:flex items-center gap-8">
        {
          navLinks.map((link) => (
            <a
              href={link.href}
              class="text-white/90 hover:text-white text-sm font-light tracking-wide link-underline transition-colors duration-200"
            >
              {link.label}
            </a>
          ))
        }
        <a href="#zamowienie" class="btn-outline ml-2 text-xs">Zamów bukiet</a>
      </nav>

      <!-- Burger -->
      <button
        id="burger"
        class="md:hidden flex flex-col gap-1.5 p-2 cursor-pointer"
        aria-label="Menu"
      >
        <span class="w-6 h-px bg-white block"></span>
        <span class="w-4 h-px bg-white block"></span>
        <span class="w-6 h-px bg-white block"></span>
      </button>
    </div>

    <!-- Mobile Menu -->
    <div
      id="mobile-menu"
      class="hidden md:hidden bg-[#3a2e31] border-t border-white/10"
    >
      <nav class="flex flex-col px-6 py-4 gap-4">
        {
          navLinks.map((link) => (
            <a
              href={link.href}
              class="text-white/90 hover:text-white text-base font-light tracking-wide py-1"
            >
              {link.label}
            </a>
          ))
        }
        <a href="#zamowienie" class="btn-primary text-center mt-2">Zamów bukiet</a>
      </nav>
    </div>
  </header>

  <!-- HERO -->
  <section
    id="hero"
    class="relative min-h-screen flex items-center justify-center overflow-hidden bg-[#3a2e31]"
  >
    <!-- Background image -->
    <div class="absolute inset-0 z-0">
      <img
        src="https://images.unsplash.com/photo-1487530811015-780780169993?auto=format&fit=crop&w=1600&q=80"
        alt="Piękne kwiaty"
        class="w-full h-full object-cover"
      />
      <!-- Gradient overlay for contrast -->
      <div
        class="absolute inset-0"
        style="background: linear-gradient(135deg, rgba(58,46,49,0.72) 0%, rgba(138,109,120,0.45) 50%, rgba(58,46,49,0.60) 100%);"
      ></div>
    </div>

    <!-- Decorative floral corner SVG -->
    <div class="absolute top-0 right-0 z-10 opacity-20 pointer-events-none select-none">
      <svg width="280" height="280" viewBox="0 0 280 280" fill="none" xmlns="http://www.w3.org/2000/svg">
        <circle cx="280" cy="0" r="180" fill="none" stroke="white" stroke-width="0.5"/>
        <circle cx="280" cy="0" r="130" fill="none" stroke="white" stroke-width="0.5"/>
        <circle cx="280" cy="0" r="80" fill="none" stroke="white" stroke-width="0.5"/>
      </svg>
    </div>

    <!-- Hero Content -->
    <div class="relative z-10 text-center text-white px-6 max-w-3xl mx-auto">
      <p
        class="text-xs uppercase tracking-[0.4em] text-white/70 mb-6 font-light"
        style="font-family: var(--font-body);"
      >
        ✿ &nbsp; Kraków, florystyka autorska &nbsp; ✿
      </p>
      <h1
        class="text-5xl md:text-7xl lg:text-8xl leading-none mb-6 drop-shadow-lg"
        style="font-family: var(--font-display);"
      >
        Kwiatowa<br />
        <em class="not-italic text-[#e8c4c1]">Pracownia</em>
      </h1>
      <p
        class="text-lg md:text-xl text-white/85 font-light leading-relaxed mb-10 max-w-xl mx-auto"
        style="font-family: var(--font-body);"
      >
        Tworzymy bukiety z duszą — każdy kwiat dobrany z intencją,
        każda kompozycja opowiada historię. Dla chwil, które zostają
        w pamięci.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
        <a href="#zamowienie" class="btn-primary">Zamów bukiet</a>
        <a href="#galeria" class="btn-outline">Zobacz realizacje</a>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div
      class="absolute bottom-8 left-1/2 -translate-x-1/2 z-10 flex flex-col items-center gap-2 text-white/50"
    >
      <span class="text-[0.65rem] tracking-widest uppercase font-light">Przewiń</span>
      <div class="w-px h-8 bg-white/30 animate-pulse"></div>
    </div>
  </section>

  <!-- O PRACOWNI -->
  <section id="o-pracowni" class="py-24 md:py-32 px-6">
    <div class="max-w-6xl mx-auto">
      <div class="grid md:grid-cols-2 gap-16 items-center">
        <!-- Image column -->
        <div class="reveal relative">
          <div
            class="absolute -top-4 -left-4 w-full h-full border border-[#cf9b97] rounded-sm pointer-events-none"
          ></div>
          <img
            src="https://images.unsplash.com/photo-1520763185298-1b434c919102?auto=format&fit=crop&w=800&q=80"
            alt="Ania Kowalska — florystka"
            class="w-full h-80 md:h-[480px] object-cover rounded-sm relative z-10"
          />
          <div
            class="absolute -bottom-6 -right-6 bg-[#cf9b97] text-white px-6 py-4 z-20 shadow-lg"
          >
            <p class="text-2xl font-display leading-none">12 lat</p>
            <p class="text-xs font-light tracking-widest uppercase mt-1">doświadczenia</p>
          </div>
        </div>

        <!-- Text column -->
        <div>
          <p class="reveal text-xs uppercase tracking-[0.3em] text-[#cf9b97] mb-4 font-light">
            Nasza historia
          </p>
          <h2
            class="reveal reveal-delay-1 text-4xl md:text-5xl leading-tight mb-6"
            style="font-family: var(--font-display);"
          >
            Kwiaciarnia z sercem
          </h2>
          <div class="reveal reveal-delay-2 space-y-4 text-[#5c4a52] font-light leading-relaxed">
            <p>
              Kwiatowa Pracownia to miejsce, gdzie florystyka staje się sztuką.
              Założyłam ją w 2012 roku z jednym marzeniem — by każdy bukiet
              był gestem miłości, starannie przemyślanym i pięknie wykonanym.
            </p>
            <p>
              Pracuję z kwiatami sezonowymi, dbam o ich świeżość i dobieram
              je z lokalnych hodowli pod Krakowem. Nie tworzę anonimowych
              wiązanek — każde zamówienie to rozmowa o Tobie, o osobie, dla
              której to przygotowuję, o chwili, którą chcesz uczcić.
            </p>
            <p>
              Moje kompozycje łączą romantyzmem z nowoczesnością — organiczne
              kształty, pastelowa paleta, subtelne akcenty zieleni.
            </p>
          </div>
          <div class="reveal reveal-delay-3 mt-8 flex gap-10">
            <div>
              <p class="text-3xl text-[#8a6d78] font-display">850+</p>
              <p class="text-xs tracking-wider uppercase font-light text-[#5c4a52]">realizacji rocznie</p>
            </div>
            <div>
              <p class="text-3xl text-[#8a6d78] font-display">120+</p>
              <p class="text-xs tracking-wider uppercase font-light text-[#5c4a52]">ślubów</p>
            </div>
            <div>
              <p class="text-3xl text-[#8a6d78] font-display">4.9 ★</p>
              <p class="text-xs tracking-wider uppercase font-light text-[#5c4a52]">ocena Google</p>
            </div>
          </div>
          <div class="reveal reveal-delay-4 mt-8">
            <p class="text-sm font-light text-[#8a6d78] italic font-display text-lg">
              — Anna Kowalska, florystka & właścicielka
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Decorative divider -->
  <div class="petal-divider py-4">✿ &nbsp;&nbsp; ✿ &nbsp;&nbsp; ✿</div>

  <!-- OFERTA -->
  <section id="oferta" class="py-24 md:py-32 px-6 bg-[#f5eeeb]">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-16">
        <p class="reveal text-xs uppercase tracking-[0.3em] text-[#cf9b97] mb-4 font-light">Co tworzymy</p>
        <h2
          class="reveal reveal-delay-1 text-4xl md:text-5xl leading-tight"
          style="font-family: var(--font-display);"
        >
          Oferta Pracowni
        </h2>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {
          services.map((s, i) => (
            <article
              class={`reveal reveal-delay-${i + 1} group bg-[#faf6f3] overflow-hidden shadow-sm hover:shadow-xl transition-shadow duration-400`}
            >
              <div class="relative overflow-hidden h-52">
                <img
                  src={`https://images.unsplash.com/photo-${s.img}?auto=format&fit=crop&w=700&q=80`}
                  alt={s.title}
                  class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                />
                <div class="absolute inset-0 bg-gradient-to-t from-[#3a2e31]/40 to-transparent"></div>
                <span class="absolute top-4 right-4 text-xl text-white/80">{s.icon}</span>
              </div>
              <div class="p-6">
                <h3 class="text-xl mb-2" style="font-family: var(--font-display);">
                  {s.title}
                </h3>
                <p class="text-sm font-light text-[#5c4a52] leading-relaxed mb-4">{s.desc}</p>
                <div class="flex items-center justify-between">
                  <span class="text-[#8a6d78] font-medium text-sm">{s.price}</span>
                  <a
                    href="#zamowienie"
                    class="text-xs uppercase tracking-widest text-[#cf9b97] hover:text-[#8a6d78] transition-colors font-light link-underline"
                  >
                    Zamów →
                  </a>
                </div>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- OPINIE -->
  <section class="py-20 px-6" style="background: linear-gradient(135deg, var(--color-mauve) 0%, var(--color-dark) 100%);">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-12">
        <p class="reveal text-xs uppercase tracking-[0.3em] text-[#cf9b97] mb-4 font-light">Co mówią klientki</p>
        <h2
          class="reveal reveal-delay-1 text-4xl md:text-5xl leading-tight text-white"
          style="font-family: var(--font-display);"
        >
          Słowa, które nas wzruszają
        </h2>
      </div>
      <div class="grid md:grid-cols-3 gap-6">
        {
          testimonials.map((t, i) => (
            <blockquote
              class={`reveal reveal-delay-${i + 1} bg-white/10 backdrop-blur-sm border border-white/15 p-6 rounded-sm`}
            >
              <p class="text-white/85 font-light text-sm leading-relaxed mb-6 italic">
                „{t.text}"
              </p>
              <footer>
                <p class="text-white font-medium text-sm">{t.name}</p>
                <p class="text-white/50 text-xs font-light mt-0.5">{t.event}</p>
              </footer>
            </blockquote>
          ))
        }
      </div>
    </div>
  </section>

  <!-- GALERIA -->
  <section id="galeria" class="py-24 md:py-32 px-6">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-12">
        <p class="reveal text-xs uppercase tracking-[0.3em] text-[#cf9b97] mb-4 font-light">Nasze realizacje</p>
        <h2
          class="reveal reveal-delay-1 text-4xl md:text-5xl leading-tight"
          style="font-family: var(--font-display);"
        >
          Galeria Kwiatów
        </h2>
      </div>

      <!-- Filter buttons -->
      <div class="reveal reveal-delay-2 flex flex-wrap gap-3 justify-center mb-10">
        {
          [
            { value: "all", label: "Wszystkie" },
            { value: "bukiety", label: "Bukiety" },
            { value: "sluby", label: "Śluby" },
            { value: "kompozycje", label: "Kompozycje" },
          ].map((f) => (
            <button
              data-filter={f.value}
              class={`text-xs uppercase tracking-widest px-5 py-2 border transition-all duration-200 font-light cursor-pointer ${f.value === "all" ? "active-filter border-[#8a6d78] bg-[#8a6d78] text-white" : "border-[#cf9b97] text-[#8a6d78] hover:bg-[#cf9b97] hover:text-white hover:border-[#cf9b97]"}`}
            >
              {f.label}
            </button>
          ))
        }
      </div>

      <!-- Gallery grid -->
      <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
        {
          galleryItems.map((item, i) => (
            <div
              data-category={item.cat}
              class={`reveal reveal-delay-${(i % 5) + 1} group relative overflow-hidden aspect-square bg-[#e8ddd8]`}
            >
              <img
                src={`https://images.unsplash.com/photo-${item.img}?auto=format&fit=crop&w=600&q=80`}
                alt={item.alt}
                class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
              />
              <div class="absolute inset-0 bg-[#3a2e31]/0 group-hover:bg-[#3a2e31]/40 transition-all duration-300 flex items-end p-4">
                <p class="text-white text-sm font-light opacity-0 group-hover:opacity-100 transition-opacity duration-300 translate-y-2 group-hover:translate-y-0">
                  {item.alt}
                </p>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ZAMÓWIENIE FORM -->
  <section id="zamowienie" class="py-24 md:py-32 px-6 bg-[#f5eeeb]">
    <div class="max-w-3xl mx-auto">
      <div class="text-center mb-12">
        <p class="reveal text-xs uppercase tracking-[0.3em] text-[#cf9b97] mb-4 font-light">Stwórzmy razem</p>
        <h2
          class="reveal reveal-delay-1 text-4xl md:text-5xl leading-tight"
          style="font-family: var(--font-display);"
        >
          Zamów Swój Bukiet
        </h2>
        <p class="reveal reveal-delay-2 text-[#5c4a52] font-light mt-4 max-w-md mx-auto">
          Wypełnij formularz, a odezwiemy się w ciągu 24 godzin, by omówić
          szczegóły Twojego zamówienia.
        </p>
      </div>

      <form
        id="order-form"
        class="reveal reveal-delay-2 bg-[#faf6f3] p-8 md:p-12 shadow-sm space-y-6"
      >
        <div class="grid md:grid-cols-2 gap-6">
          <div>
            <label class="block text-xs uppercase tracking-wider text-[#8a6d78] mb-2 font-light">
              Imię i nazwisko *
            </label>
            <input
              type="text"
              required
              placeholder="Anna Nowak"
              class="w-full border border-[#e8ddd8] bg-white px-4 py-3 text-sm font-light text-[#3a2e31] placeholder-[#9aaa8b] transition-all duration-200"
            />
          </div>
          <div>
            <label class="block text-xs uppercase tracking-wider text-[#8a6d78] mb-2 font-light">
              Telefon *
            </label>
            <input
              type="tel"
              required
              placeholder="+48 500 600 700"
              class="w-full border border-[#e8ddd8] bg-white px-4 py-3 text-sm font-light text-[#3a2e31] placeholder-[#9aaa8b] transition-all duration-200"
            />
          </div>
        </div>

        <div>
          <label class="block text-xs uppercase tracking-wider text-[#8a6d78] mb-2 font-light">
            E-mail *
          </label>
          <input
            type="email"
            required
            placeholder="anna@example.com"
            class="w-full border border-[#e8ddd8] bg-white px-4 py-3 text-sm font-light text-[#3a2e31] placeholder-[#9aaa8b] transition-all duration-200"
          />
        </div>

        <div class="grid md:grid-cols-2 gap-6">
          <div>
            <label class="block text-xs uppercase tracking-wider text-[#8a6d78] mb-2 font-light">
              Okazja *
            </label>
            <select
              required
              class="w-full border border-[#e8ddd8] bg-white px-4 py-3 text-sm font-light text-[#3a2e31] transition-all duration-200 appearance-none cursor-pointer"
            >
              <option value="">— wybierz —</option>
              {okazjeOptions.map((o) => <option value={o}>{o}</option>)}
            </select>
          </div>
          <div>
            <label class="block text-xs uppercase tracking-wider text-[#8a6d78] mb-2 font-light">
              Budżet
            </label>
            <select
              class="w-full border border-[#e8ddd8] bg-white px-4 py-3 text-sm font-light text-[#3a2e31] transition-all duration-200 appearance-none cursor-pointer"
            >
              <option value="">— wybierz —</option>
              {budzetOptions.map((b) => <option value={b}>{b}</option>)}
            </select>
          </div>
        </div>

        <div>
          <label class="block text-xs uppercase tracking-wider text-[#8a6d78] mb-2 font-light">
            Termin realizacji *
          </label>
          <input
            type="date"
            required
            class="w-full border border-[#e8ddd8] bg-white px-4 py-3 text-sm font-light text-[#3a2e31] transition-all duration-200"
          />
        </div>

        <div>
          <label class="block text-xs uppercase tracking-wider text-[#8a6d78] mb-2 font-light">
            Dodatkowe informacje / inspiracje
          </label>
          <textarea
            rows="4"
            placeholder="Ulubione kwiaty, kolory, nastrój, do czego ma pasować..."
