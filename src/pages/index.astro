<style>
  /* Nav scrolled state */
  #nav {
    background: transparent;
    border-bottom: 1px solid transparent;
  }
  #nav.scrolled {
    background: color-mix(in srgb, var(--color-cream) 95%, transparent);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--color-rule);
  }

  /* Gallery filter button states */
  .filter-active {
    background: var(--color-mauve) !important;
    border-color: var(--color-mauve) !important;
    color: var(--color-cream) !important;
  }
  .filter-btn:hover {
    border-color: var(--color-rose);
    color: var(--color-rose);
  }

  /* Service grid layout — responsive */
  [data-service-idx] {
    grid-template-columns: 2.5rem 1fr 1fr;
  }
  @media (max-width: 767px) {
    [data-service-idx] {
      grid-template-columns: 2rem 1fr !important;
    }
    [data-service-idx] > div:last-child {
      grid-column: 1 / -1 !important;
      grid-row: 2 !important;
    }
  }
</style>

<script>
  // Gallery filter
  const filterBtns = document.querySelectorAll<HTMLButtonElement>("[data-filter]");
  const galleryItems = document.querySelectorAll<HTMLElement>("[data-category]");
  filterBtns.forEach((btn) => {
    btn.addEventListener("click", () => {
      filterBtns.forEach(b => {
        b.classList.remove("filter-active");
        b.classList.add("filter-btn");
      });
      btn.classList.add("filter-active");
      btn.classList.remove("filter-btn");
      const filter = btn.dataset.filter;
      galleryItems.forEach((item) => {
        const show = filter === "all" || item.dataset.category === filter;
        (item as HTMLElement).style.display = show ? "block" : "none";
      });
    });
  });

  // Form submit mock
  const form = document.getElementById("order-form") as HTMLFormElement | null;
  const submitBtn = document.getElementById("order-submit");
  form?.addEventListener("submit", (e) => {
    e.preventDefault();
    if (submitBtn) {
      const orig = submitBtn.textContent;
      submitBtn.textContent = "Wysłano — odezwiemy się wkrótce ✿";
      (submitBtn as HTMLButtonElement).style.color = "var(--color-sage)";
      (submitBtn as HTMLButtonElement).style.borderColor = "var(--color-sage)";
      setTimeout(() => {
        if (submitBtn) {
          submitBtn.textContent = orig;
          (submitBtn as HTMLButtonElement).style.color = "";
          (submitBtn as HTMLButtonElement).style.borderColor = "";
          form?.reset();
        }
      }, 4000);
    }
  });
</script>
