---
import Layout from "../layouts/Layout.astro";

const navLinks = [
  { href: "#o-pracowni", label: "O Pracowni" },
  { href: "#oferta", label: "Oferta" },
  { href: "#galeria", label: "Galeria" },
  { href: "#zamowienie", label: "Zamówienie" },
  { href: "#kontakt", label: "Kontakt" },
];

const services = [
  {
    num: "01",
    title: "Bukiety Okolicznościowe",
    desc: "Ręcznie komponowane bukiety na urodziny, imieniny, rocznice i każdą wyjątkową chwilę. Każdy jest jedynym w swoim rodzaju.",
    price: "od 80 zł",
    detail: "urodziny · imieniny · rocznice",
    img: "photo-1487530811015-780780169993",
  },
  {
    num: "02",
    title: "Florystyka Ślubna",
    desc: "Wiązanki ślubne, dekoracje stołów, łuki kwiatowe, chodniki — tworzymy spójną narrację kwiatową na Wasz wyjątkowy dzień.",
    price: "od 600 zł",
    detail: "wiązanki · dekoracje stołów · łuki",
    img: "photo-1519225421980-715cb0215aed",
  },
  {
    num: "03",
    title: "Wiązanki & Kosze",
    desc: "Eleganckie kompozycje w koszach wiklinowych, welurowych pudłach i papierze czerpanym. Idealne jako prezent.",
    price: "od 120 zł",
    detail: "kosze · pudła · papier czerpany",
    img: "photo-1490750967868-88df5691cc6c",
  },
  {
    num: "04",
    title: "Kwiaty na Okazje",
    desc: "Chrzciny, komunie, baby shower, pożegnania, firmowe gale — dobieramy kompozycje dopasowane do nastroju i miejsca.",
    price: "od 150 zł",
    detail: "chrzciny · komunia · baby shower",
    img: "photo-1467043237213-65f2da53396f",
  },
  {
    num: "05",
    title: "Abonament Kwiatowy",
    desc: "Regularne dostawy świeżych kompozycji do domu lub biura — co tydzień, co dwa tygodnie lub raz w miesiącu.",
    price: "od 180 zł / mies.",
    detail: "tygodniowy · dwutygodniowy · miesięczny",
    img: "photo-1520763185298-1b434c919102",
  },
];

const galleryItems = [
  { img: "photo-1487530811015-780780169993", alt: "Bukiet z piwonii i róż", cat: "bukiety" },
  { img: "photo-1519225421980-715cb0215aed", alt: "Ślubna wiązanka z białych kwiatów", cat: "sluby" },
  { img: "photo-1490750967868-88df5691cc6c", alt: "Kosz z wiosennymi kwiatami", cat: "kompozycje" },
  { img: "photo-1562690868-60bbe7293e4b", alt: "Romantyczna kompozycja w wazonie", cat: "kompozycje" },
  { img: "photo-1508610048659-a06b669e3321", alt: "Pastelowy bukiet ślubny", cat: "sluby" },
  { img: "photo-1457296898342-cdd24585d095", alt: "Wiosenny bukiet z ranunkułów", cat: "bukiety" },
  { img: "photo-1530103862676-de8c9debad1d", alt: "Dekoracja stołu kwiatami", cat: "sluby" },
  { img: "photo-1444930694458-01babf71ab6b", alt: "Suszone kwiaty w kompozycji", cat: "kompozycje" },
  { img: "photo-1471086569966-db3eebc25a59", alt: "Kolorowy bukiet wiosennych kwiatów", cat: "bukiety" },
];

const testimonials = [
  {
    name: "Marta K.",
    event: "Ślub, sierpień 2024",
    text: "Kwiatowa Pracownia dosłownie spełniła moje marzenia o ślubie. Wiązanka była dokładnie taka, jak sobie wyobrażałam — delikatna, romantyczna, z piwoniami i eukaliptusem. Polecam z całego serca!",
  },
  {
    name: "Zofia W.",
    event: "Abonament miesięczny",
    text: "Od roku co dwa tygodnie dostaję bukiet i za każdym razem jest inaczej i pięknie. Świeże kwiaty potrafią zmienić nastrój całego domu.",
  },
  {
    name: "Anna M.",
    event: "Urodziny, maj 2024",
    text: "Zamówiłam bukiet dla mamy — dostałam przepiękną kompozycję w jej ulubionych kolorach, jeszcze przed planowaną godziną. Mama była wzruszona!",
  },
];

const okazjeOptions = [
  "Urodziny / imieniny",
  "Ślub / wesele",
  "Rocznica",
  "Chrzciny / komunia",
  "Baby shower",
  "Podziękowanie",
  "Dekoracja biura / domu",
  "Abonament kwiatowy",
  "Inna okazja",
];

const budzetOptions = [
  "do 100 zł",
  "100–200 zł",
  "200–400 zł",
  "400–800 zł",
  "powyżej 800 zł",
];
---

<Layout
  title="Kwiatowa Pracownia — Florystyka Autorska | Kraków"
  description="Kwiatowa Pracownia — autorska florystyka w Krakowie. Bukiety okolicznościowe, dekoracje ślubne, wiązanki, kwiaty na każdą okazję."
>

  <!-- ═══════════════════════════════════════ -->
  <!-- NAV — thin editorial bar               -->
  <!-- ═══════════════════════════════════════ -->
  <header id="nav" class="fixed left-0 right-0 z-50 transition-all duration-500">
    <div class="px-6 md:px-10 flex items-center justify-between h-14 md:h-16">
      <!-- Logo -->
      <a href="#" class="flex items-baseline gap-3">
        <span style="font-family:var(--font-display); font-size:1.35rem; color:var(--color-dark); letter-spacing:0.02em; line-height:1;">Kwiatowa Pracownia</span>
        <span style="font-family:var(--font-mono); font-size:0.5rem; letter-spacing:0.2em; text-transform:uppercase; color:var(--color-rose);">Kraków</span>
      </a>

      <!-- Desktop nav -->
      <nav class="hidden md:flex items-center gap-8">
        {navLinks.map(l => (
          <a
            href={l.href}
            style="font-family:var(--font-mono); font-size:0.6rem; letter-spacing:0.15em; text-transform:uppercase; color:var(--color-dark); opacity:0.55; transition:opacity 0.2s; text-decoration:none;"
            onmouseover="this.style.opacity='1'"
            onmouseout="this.style.opacity='0.55'"
          >{l.label}</a>
        ))}
      </nav>

      <!-- CTA -->
      <a href="#zamowienie" class="hidden md:inline-flex btn-ed">
        Zamów bukiet <span style="color:var(--color-rose);">→</span>
      </a>

      <!-- Burger -->
      <button id="burger" class="md:hidden flex flex-col gap-1.5 p-2" aria-label="Menu">
        <span class="block w-6 h-px bg-current" style="color:var(--color-dark);"></span>
        <span class="block w-6 h-px bg-current" style="color:var(--color-dark);"></span>
        <span class="block w-4 h-px bg-current" style="color:var(--color-dark);"></span>
      </button>
    </div>

    <!-- Mobile menu -->
    <div id="mobile-menu" class="hidden md:hidden" style="background:var(--color-cream); border-top:1px solid var(--color-rule);">
      <nav class="flex flex-col px-6 py-6 gap-5">
        {navLinks.map(l => (
          <a
            href={l.href}
            style="font-family:var(--font-mono); font-size:0.7rem; letter-spacing:0.15em; text-transform:uppercase; color:var(--color-dark); text-decoration:none;"
          >{l.label}</a>
        ))}
        <a href="#zamowienie" class="btn-ed mt-2 self-start">Zamów bukiet →</a>
      </nav>
    </div>
  </header>


  <!-- ═══════════════════════════════════════ -->
  <!-- HERO — editorial masthead              -->
  <!-- ═══════════════════════════════════════ -->
  <section style="background:var(--color-cream); padding-top:calc(2.25rem + 3.5rem); min-height:100svh; display:flex; flex-direction:column; overflow:hidden; position:relative;">

    <!-- Top meta strip -->
    <div class="px-6 md:px-10 flex items-center justify-between py-3" style="border-top:1px solid var(--color-rule);">
      <span style="font-family:var(--font-mono); font-size:0.58rem; letter-spacing:0.18em; text-transform:uppercase; color:#b0a49e;">Florystyka · Kraków · od 2012</span>
      <span style="font-family:var(--font-mono); font-size:0.58rem; letter-spacing:0.18em; text-transform:uppercase; color:#b0a49e;">✿ pracownia autorska</span>
    </div>

    <!-- Main editorial grid -->
    <div class="px-6 md:px-10 flex-1 grid grid-cols-1 md:grid-cols-12 items-end gap-0">

      <!-- LEFT: giant headline -->
      <div class="md:col-span-8 pb-8 md:pb-16 reveal">
        <div class="mb-5 flex items-center gap-3">
          <span style="display:block; width:2.5rem; height:1px; background:var(--color-rose);"></span>
          <span style="font-family:var(--font-mono); font-size:0.58rem; letter-spacing:0.2em; text-transform:uppercase; color:var(--color-rose);">Kwiatowa Pracownia</span>
        </div>

        <h1 style="
          font-family:var(--font-display);
          font-weight:400;
          font-size: clamp(5.5rem, 13vw, 14rem);
          line-height:0.88;
          letter-spacing:-0.01em;
          color:var(--color-dark);
          margin-bottom:0;
        " class="reveal reveal-delay-1">
          Kwiaty<br>
          <em style="font-style:italic; color:var(--color-rose);">z duszą.</em>
        </h1>
      </div>

      <!-- RIGHT: stacked info -->
      <div class="md:col-span-4 md:self-center md:pl-6 pb-8 md:pb-16 reveal reveal-delay-2">
        <div class="h-rule mb-5"></div>
        <p style="font-family:var(--font-body); font-weight:300; font-size:0.9rem; line-height:1.85; color:#6a5a5e; max-width:28ch; margin-bottom:1.8rem;">
          Każdy kwiat dobrany z intencją, każda kompozycja opowiada historię — dla chwil, które zostają w pamięci.
        </p>
        <div style="display:flex; flex-direction:column; gap:0.8rem;">
          <a href="#zamowienie" class="btn-ed">Zamów bukiet →</a>
          <a href="#galeria" class="btn-ed">Zobacz realizacje →</a>
        </div>
      </div>
    </div>

    <!-- Stats strip -->
    <div class="grid grid-cols-3" style="border-top:1px solid var(--color-rule);">
      {[
        { num: "850+", label: "realizacji rocznie" },
        { num: "120+", label: "ślubów" },
        { num: "4.9 ★", label: "ocena Google" },
      ].map((s, i) => (
        <div class={`px-6 md:px-10 py-4 reveal reveal-delay-${i+1}`} style={`${i < 2 ? 'border-right:1px solid var(--color-rule);' : ''}`}>
          <div style="font-family:var(--font-display); font-size:clamp(1.4rem,3vw,2.2rem); color:var(--color-dark); line-height:1;">{s.num}</div>
          <div style="font-family:var(--font-mono); font-size:0.55rem; letter-spacing:0.14em; text-transform:uppercase; color:#b0a49e; margin-top:0.3rem;">{s.label}</div>
        </div>
      ))}
    </div>

    <!-- Full-bleed image strip -->
    <div class="relative overflow-hidden reveal" style="height:clamp(200px,32vw,440px);">
      <img
        src="https://images.unsplash.com/photo-1490750967868-88df5691cc6c?auto=format&fit=crop&w=1800&q=85"
        alt="Kwiatowa Pracownia — kompozycje"
        style="width:100%; height:100%; object-fit:cover; object-position:center 55%; display:block;"
      />
      <div style="position:absolute; top:0; left:0; right:0; height:1px; background:var(--color-rose); opacity:0.3;"></div>
      <!-- Diagonal offset label -->
      <div style="position:absolute; bottom:1.5rem; right:2rem; font-family:var(--font-mono); font-size:0.52rem; letter-spacing:0.22em; text-transform:uppercase; color:rgba(250,246,243,0.5);">Kraków · sezon 2025</div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════ -->
  <!-- O PRACOWNI — asymetryczny 2-col        -->
  <!-- ═══════════════════════════════════════ -->
  <section id="o-pracowni" style="background:var(--color-cream); padding:6rem 0 5rem; overflow:hidden;">
    <div class="px-6 md:px-10">

      <!-- Section header z numerem -->
      <div class="flex items-center gap-4 mb-12 reveal">
        <span class="section-num">01 / O Pracowni</span>
        <div style="flex:1; height:1px; background:var(--color-rule);"></div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-12 gap-8 md:gap-0 items-start">

        <!-- Rotated label (desktop) -->
        <div class="hidden md:flex md:col-span-1 items-start justify-center pt-2">
          <span style="font-family:var(--font-mono); font-size:0.55rem; letter-spacing:0.18em; text-transform:uppercase; color:var(--color-rose); writing-mode:vertical-rl; transform:rotate(180deg); white-space:nowrap;">Kwiat · Pasja · Rzemiosło</span>
        </div>

        <!-- Text block -->
        <div class="md:col-span-5 md:col-start-2 md:pr-8 reveal reveal-delay-1">
          <h2 style="font-family:var(--font-display); font-weight:400; font-size:clamp(2.4rem,5vw,4.2rem); line-height:1.02; letter-spacing:-0.01em; color:var(--color-dark); margin-bottom:1.5rem;">
            Kwiaciarnia<br>z sercem,<br>
            <em style="font-style:italic; color:var(--color-rose);">z Krakowa.</em>
          </h2>
          <div class="h-rule-rose mb-6"></div>
          <div style="font-family:var(--font-body); font-weight:300; font-size:0.92rem; line-height:1.9; color:#6a5a5e;">
            <p style="margin-bottom:1rem;">Kwiatowa Pracownia to miejsce, gdzie florystyka staje się sztuką. Założyłam ją w 2012 roku z jednym marzeniem — by każdy bukiet był gestem miłości, starannie przemyślanym i pięknie wykonanym.</p>
            <p style="margin-bottom:1rem;">Pracuję z kwiatami sezonowymi, dbam o ich świeżość i dobieram je z lokalnych hodowli pod Krakowem. Nie tworzę anonimowych wiązanek — każde zamówienie to rozmowa o Tobie i chwili, którą chcesz uczcić.</p>
            <p>Moje kompozycje łączą romantyzm z nowoczesnością — organiczne kształty, pastelowa paleta, subtelne akcenty zieleni.</p>
          </div>

          <!-- Signature -->
          <div class="mt-8 pt-6 reveal reveal-delay-3" style="border-top:1px solid var(--color-rule);">
            <p style="font-family:var(--font-display); font-style:italic; font-size:1.1rem; color:var(--color-mauve);">— Anna Kowalska, florystka & właścicielka</p>
          </div>
        </div>

        <!-- Image block — nachodzi na sąsiednią kolumnę -->
        <div class="md:col-span-5 md:col-start-8 reveal reveal-delay-2" style="position:relative; margin-top:0;">
          <div class="img-frame" style="position:relative; z-index:1;">
            <img
              src="https://images.unsplash.com/photo-1520763185298-1b434c919102?auto=format&fit=crop&w=900&q=80"
              alt="Anna Kowalska — florystka"
              style="width:100%; aspect-ratio:4/5; object-fit:cover; display:block;"
            />
          </div>
          <!-- Floating overlay stat -->
          <div style="position:absolute; bottom:-1.5rem; left:-1.2rem; background:var(--color-mauve); color:var(--color-cream); padding:1.1rem 1.5rem; z-index:10;">
            <div style="font-family:var(--font-display); font-size:1.8rem; line-height:1; color:var(--color-rose);">12 lat</div>
            <div style="font-family:var(--font-mono); font-size:0.52rem; letter-spacing:0.16em; text-transform:uppercase; margin-top:0.3rem; opacity:0.65;">doświadczenia</div>
          </div>
        </div>
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════ -->
  <!-- OFERTA — staggered editorial layout    -->
  <!-- ═══════════════════════════════════════ -->
  <section id="oferta" style="background:var(--color-parchment); padding:6rem 0;">
    <div class="px-6 md:px-10">

      <!-- Section header -->
      <div class="flex items-center gap-4 mb-4 reveal">
        <span class="section-num">02 / Oferta</span>
        <div style="flex:1; height:1px; background:var(--color-rule);"></div>
      </div>

      <h2 class="reveal reveal-delay-1" style="font-family:var(--font-display); font-weight:400; font-size:clamp(2.5rem,6vw,5.2rem); line-height:1.0; letter-spacing:-0.01em; color:var(--color-dark); margin-bottom:0.5rem;">
        Co tworzymy<br><em style="font-style:italic; color:var(--color-rose);">dla Ciebie</em>
      </h2>
      <p class="reveal reveal-delay-2" style="font-family:var(--font-body); font-weight:300; font-size:0.92rem; color:#8a7a7e; max-width:48ch; margin-bottom:4.5rem; line-height:1.8;">
        Każdą kompozycję tworzymy od podstaw, dobierając kwiaty sezonowe do okazji, nastroju i Twoich upodobań.
      </p>

      <!-- Services: alternating layout, nachodzące kolumny -->
      <div style="display:flex; flex-direction:column; gap:0;">
        {services.map((s, i) => (
          <div class={`reveal reveal-delay-${(i%3)+1}`} style="border-top:1px solid var(--color-rule); padding:2.5rem 0; display:grid; align-items:start; gap:2rem;" data-service-idx={i}>
            <!-- Numer -->
            <div style="font-family:var(--font-mono); font-size:0.62rem; letter-spacing:0.2em; color:var(--color-rose); padding-top:0.2rem; grid-column:1;">{s.num}</div>

            <!-- Name + desc -->
            <div style="grid-column:2; grid-row:1;">
              <h3 style="font-family:var(--font-display); font-weight:400; font-size:clamp(1.5rem,3vw,2.3rem); color:var(--color-dark); margin-bottom:0.7rem; line-height:1.05;">{s.title}</h3>
              <p style="font-family:var(--font-body); font-weight:300; font-size:0.88rem; line-height:1.8; color:#6a5a5e; max-width:52ch; margin-bottom:0.8rem;">{s.desc}</p>
              <div style="display:flex; align-items:center; gap:1.5rem; flex-wrap:wrap;">
                <span style="font-family:var(--font-mono); font-size:0.56rem; letter-spacing:0.14em; text-transform:uppercase; color:var(--color-rose);">{s.detail}</span>
                <span style="font-family:var(--font-display); font-size:1.05rem; color:var(--color-mauve);">{s.price}</span>
              </div>
            </div>

            <!-- Image in thin frame -->
            <div style="grid-column:3; grid-row:1; position:relative;">
              <img
                src={`https://images.unsplash.com/photo-${s.img}?auto=format&fit=crop&w=600&q=80`}
                alt={s.title}
                style="width:100%; aspect-ratio:4/3; object-fit:cover; display:block;"
              />
              <div style="position:absolute; inset:0; border:1px solid var(--color-rose); opacity:0.18; pointer-events:none;"></div>
            </div>
          </div>
        ))}
      </div>

      <div class="reveal" style="margin-top:3rem; border-top:1px solid var(--color-rule); padding-top:2rem;">
        <a href="#zamowienie" class="btn-ed">Zamów swoją kompozycję →</a>
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════ -->
  <!-- GALERIA — loose asymmetric mosaic      -->
  <!-- ═══════════════════════════════════════ -->
  <section id="galeria" style="background:var(--color-cream); padding:6rem 0;">
    <div class="px-6 md:px-10">

      <!-- Section header -->
      <div class="flex items-center gap-4 mb-4 reveal">
        <span class="section-num">03 / Galeria</span>
        <div style="flex:1; height:1px; background:var(--color-rule);"></div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-12 items-end mb-10 gap-4">
        <div class="md:col-span-6 reveal reveal-delay-1">
          <h2 style="font-family:var(--font-display); font-weight:400; font-size:clamp(2.5rem,6vw,5rem); line-height:1.0; letter-spacing:-0.01em; color:var(--color-dark);">
            Nasze<br><em style="font-style:italic; color:var(--color-rose);">realizacje</em>
          </h2>
        </div>
        <!-- Filter buttons — editorial pill style -->
        <div class="md:col-span-6 reveal reveal-delay-2 flex flex-wrap items-center gap-2 md:justify-end">
          {[
            { value: "all", label: "Wszystkie" },
            { value: "bukiety", label: "Bukiety" },
            { value: "sluby", label: "Śluby" },
            { value: "kompozycje", label: "Kompozycje" },
          ].map((f) => (
            <button
              data-filter={f.value}
              style="font-family:var(--font-mono); font-size:0.58rem; letter-spacing:0.14em; text-transform:uppercase; padding:0.35rem 0.9rem; border:1px solid var(--color-rule); color:var(--color-dark); background:transparent; cursor:pointer; transition:all 0.2s;"
              class={f.value === "all" ? "filter-active" : "filter-btn"}
            >
              {f.label}
            </button>
          ))}
        </div>
      </div>

      <!-- Gallery: 3-col mosaic (nachodzące rozmiary) -->
      <div class="grid grid-cols-2 md:grid-cols-3 gap-3 md:gap-4" id="gallery-grid">
        {galleryItems.map((item, i) => (
          <div
            data-category={item.cat}
            class={`reveal reveal-delay-${(i % 4)+1} gal-frame overflow-hidden`}
            style={`aspect-ratio: ${i === 0 || i === 4 ? '3/4' : i === 2 || i === 6 ? '1/1' : '4/3'}; background:var(--color-parchment);`}
          >
            <img
              src={`https://images.unsplash.com/photo-${item.img}?auto=format&fit=crop&w=700&q=80`}
              alt={item.alt}
              style="width:100%; height:100%; object-fit:cover; display:block; transition:transform 0.5s cubic-bezier(.16,1,.3,1);"
              onmouseover="this.style.transform='scale(1.04)'"
              onmouseout="this.style.transform='scale(1)'"
            />
          </div>
        ))}
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════ -->
  <!-- OPINIE — ciemny pas z pull-quotes      -->
  <!-- ═══════════════════════════════════════ -->
  <section style="background:var(--color-dark); padding:6rem 0; position:relative; overflow:hidden;">
    <!-- Rose top rule -->
    <div style="position:absolute; top:0; left:0; right:0; height:1px; background:linear-gradient(90deg,transparent,var(--color-rose),transparent); opacity:0.3;"></div>

    <div class="px-6 md:px-10">
      <div class="flex items-center gap-4 mb-12 reveal">
